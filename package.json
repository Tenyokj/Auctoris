{
  "name": "auctoris-licensing-authority",
  "version": "1.0.0",
  "description": "Auctoris Licensing Authority: upgradeable on-chain license registry and ERC-1155 access key protocol.",
  "type": "module",
  "scripts": {
    "test": "hardhat test",
    "compile": "hardhat compile",
    "coverage": "hardhat test --coverage",
    "deploy:protocol": "hardhat run scripts/deploy/deploy-license-protocol.ts",
    "deploy:protocol:upgradeable": "hardhat run scripts/deploy/deploy-license-protocol.ts",
    "deploy:localhost": "hardhat run --network localhost scripts/deploy/deploy-license-protocol.ts",
    "deploy:sepolia": "hardhat run --network sepolia scripts/deploy/deploy-license-protocol.ts",
    "ops:transfer-safe:sepolia": "hardhat run --network sepolia scripts/ops/transfer-proxy-admin-to-safe.ts",
    "ops:upgrade:sepolia": "hardhat run --network sepolia scripts/ops/upgrade-proxy.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.3",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.2",
    "@nomicfoundation/hardhat-ignition": "^3.0.5",
    "@nomicfoundation/hardhat-mocha": "^3.0.7",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.3",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.1",
    "@nomicfoundation/hardhat-typechain": "^3.0.1",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.1",
    "chai": "^5.3.3",
    "dotenv": "^17.2.3",
    "ethers": "^6.15.0",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.0.15",
    "mocha": "^11.7.5",
    "solidity-coverage": "^0.8.0-beta.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=22.10"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-ignition-ethers": "^3.0.5",
    "@openzeppelin/contracts": "^5.0.2",
    "@openzeppelin/contracts-upgradeable": "^5.0.2",
    "@tenyokj/scsl-contracts": "^1.0.0",
    "viem": "^2.43.3",
    "wagmi": "^3.1.3"
  }
}
