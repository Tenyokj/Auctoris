# ==============================
# Network RPC URLs
# ==============================
LOCAL_RPC_URL=http://127.0.0.1:8545
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ==============================
# Deployer Wallet
# ==============================
# Private key must include 0x prefix.
# Never commit real keys to git.
DEPLOYER_KEY=0xYOUR_PRIVATE_KEY
DEPLOYER_ADDRESS=0xYOUR_DEPLOYER_ADDRESS
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ==============================
# Tenji token + airdrop deploy
# ==============================
# Required on Sepolia. Local deployments fall back to the deployer.
LIQUIDITY_WALLET=0xYOUR_LIQUIDITY_WALLET
TEAM_WALLET=0xYOUR_TEAM_WALLET
RESERVE_WALLET=0xYOUR_RESERVE_WALLET

# Optional. Defaults to deployer.
AIRDROP_OWNER=0xYOUR_AIRDROP_OWNER

# Recommended everywhere, required on Sepolia.
# 20,000,000,000 TENJI / 100,000 users = 200,000 TENJI per user.
# Human-readable amounts, 18 decimals assumed.
AIRDROP_AMOUNT_PER_USER=200000
AIRDROP_MAX_USERS=100000
