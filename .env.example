# Auctoris Licensing Authority
# Copy this file to `.env` and fill in the values before deploying.

# Local development RPC.
LOCAL_RPC_URL=http://127.0.0.1:8545

# Ethereum Sepolia RPC endpoint.
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_API_KEY

# Deployer private key used by Hardhat.
# You may provide it with or without the 0x prefix.
DEPLOYER_KEY=

# Optional Etherscan API key used for source-code verification.
ETHERSCAN_API_KEY=

# Safe multisig address used as the long-term owner of ProxyAdmin contracts.
SAFE_MULTISIG_ADDRESS=

# Optional path override for deployment manifests.
DEPLOYMENT_MANIFEST_PATH=

# Optional scope for ownership transfer.
# Supported values: all, registry, token
PROXY_ADMIN_SCOPE=all

# Upgrade target used by the upgrade script.
# Supported values: registry, token
UPGRADE_TARGET=

# Optional calldata to execute during upgrade.
# Use 0x for no post-upgrade call.
UPGRADE_CALLDATA=0x
