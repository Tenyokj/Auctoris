# ==============================
# Network RPC URLs
# ==============================
LOCAL_RPC_URL=http://127.0.0.1:8545
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ==============================
# Deployer Wallet
# ==============================
# Private key must include 0x prefix.
# Never commit real keys to git.
DEPLOYER_KEY=0xYOUR_PRIVATE_KEY
DEPLOYER_ADDRESS=0xYOUR_DEPLOYER_ADDRESS

# ==============================
# Deploy Config (scripts/dex/deploy-proxies.ts)
# ==============================
# Optional: if empty, deployer becomes owner of per-proxy ProxyAdmin contracts
PROXY_ADMIN_OWNER=0xYOUR_PROXY_ADMIN_OWNER

# Optional: if empty, script deploys MockWETH
WETH_ADDRESS=

# Fee and governance config
SWAP_FEE_BPS=30
PROTOCOL_FEE_BPS=5
FLASH_DEFAULT_MAX_OUT_BPS=3000
GOV_MIN_DELAY=3600

# Optional: transfer factory ownership to governance after deployment
TRANSFER_FACTORY_TO_GOVERNANCE=false

# ==============================
# Upgrade Config (scripts/dex/upgrade-proxy.ts)
# ==============================
PROXY_ADMIN=
PROXY=
IMPL=
CALL=
ARGS=[]
GAS_LIMIT=

# ==============================
# Verify Config (scripts/dex/verify-deploy.ts)
# Populate after deployment
# ==============================
DEX_WETH=
DEX_FACTORY=
DEX_ROUTER=
DEX_ROUTER_V2=
DEX_ORACLE=
DEX_FEE_COLLECTOR=
DEX_FLASH_LIMITER=
DEX_GOVERNANCE=
